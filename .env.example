# easyPhoto — build-time environment variables
# Copy to .env.production (or set in your host's dashboard) and rebuild.

# Canonical site origin. Drives canonical URLs, OpenGraph, sitemap, robots.
# No trailing slash.
NEXT_PUBLIC_SITE_URL=https://easyphoto.in

# Search-engine ownership verification (optional — renders <meta> only when set).
# Google Search Console → Settings → Ownership verification → "HTML tag":
#   copy ONLY the content="..." value here.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools → "Meta tag" option → the msvalidate.01 content value.
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# AdSense ad-serving runtime. BAKED IN AT BUILD TIME (NEXT_PUBLIC_* vars are
# inlined by Next.js — changing this in a host dashboard requires a rebuild).
# Keep unset (or "false") until AdSense approval and planned ad slots are ready.
# Excluded paths are hardcoded in components/site/AdSenseScript.tsx.
NEXT_PUBLIC_ADSENSE_ENABLED=false
