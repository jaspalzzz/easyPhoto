# Security headers for static hosting (Netlify / Cloudflare Pages).
# This is a STATIC EXPORT, so headers cannot come from next.config — they are
# applied here at the CDN/host layer. (Vercel: see vercel.json.)
#
# The single highest-leverage control is the CSP `connect-src` allowlist: it
# makes the "your image never leaves your device" promise BROWSER-ENFORCED —
# injected code physically cannot POST image bytes to any origin not listed.
# Once the ML wasm/models are self-hosted, drop the CDN entries and tighten to
# connect-src 'self'.
/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data: blob: https://pagead2.googlesyndication.com https://ep1.adtrafficquality.google; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' blob: https://cdn.jsdelivr.net https://pagead2.googlesyndication.com https://fundingchoicesmessages.google.com https://ep2.adtrafficquality.google https://static.cloudflareinsights.com; worker-src 'self' blob: https://cdn.jsdelivr.net; frame-src https://googleads.g.doubleclick.net https://fundingchoicesmessages.google.com https://ep2.adtrafficquality.google https://www.google.com; connect-src 'self' blob: https://models.easyphoto.in https://cdn.jsdelivr.net https://storage.googleapis.com https://huggingface.co https://*.huggingface.co https://*.hf.co https://pagead2.googlesyndication.com https://fundingchoicesmessages.google.com https://ep1.adtrafficquality.google https://cloudflareinsights.com; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  # Google's European-regulations messages need the site origin on their
  # cross-origin request; no-referrer can make a published message ineligible.
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(), geolocation=(), payment=(), usb=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless

# Content-hashed build assets (JS/CSS chunks, bundled wasm/models under media/)
# are immutable — the hash changes when content changes — so cache them forever.
# This is the main lever for the edge cache-hit rate and repeat-visit bandwidth.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Site identity assets (favicons, PWA icons, manifest). Short TTL so a brand
# refresh propagates to all users within a day without needing filename hashing.
/favicon*
  Cache-Control: public, max-age=86400
/icon*
  Cache-Control: public, max-age=86400
/apple-touch-icon.png
  Cache-Control: public, max-age=86400
/logo.svg
  Cache-Control: public, max-age=86400
# site.webmanifest is the real filename (app/layout.tsx manifest: "/site.webmanifest");
# this rule previously targeted /manifest.json, which doesn't exist, so the
# manifest shipped with no cache header at all. noindex for the same reason as
# opengraph-image: it's an asset Google crawls but should never index as a page.
/site.webmanifest
  Cache-Control: public, max-age=86400
  X-Robots-Tag: noindex

# Per-page Open Graph cards are emitted as EXTENSIONLESS files (…/opengraph-image).
# With nosniff above, the host must declare the type explicitly or social/SERP
# previews break. Cloudflare Pages reads this _headers file and applies it.
# noindex: these are social-preview assets, not pages — Google crawls them
# (they're in every page's og:image meta) and lists them under "Crawled -
# currently not indexed" in Search Console, ~60 URLs of report noise that
# looks like a content-quality problem but isn't. The header moves them to
# the explicit "Excluded by noindex" bucket. Social platforms fetch preview
# images directly and ignore robots headers, so link previews are unaffected.
/*opengraph-image
  Content-Type: image/png
  Cache-Control: public, max-age=86400
  X-Robots-Tag: noindex

# The exam-calendar .ics is exported extensionless; declare its type so phones
# hand it to the calendar app instead of showing raw text.
/exam-calendar/ics
  Content-Type: text/calendar; charset=utf-8
  Content-Disposition: attachment; filename="easyphoto-exam-calendar.ics"

# Combined portal resizer tool pages — noindexed to keep /exam-requirements/{exam}/
# as the single indexed canonical per portal. Pages remain live (tool still works).
/tools/form-resizer/*
  X-Robots-Tag: noindex, follow

# Embeddable exam-spec widgets for referral and brand exposure. The copied
# snippet's parent-document anchor provides the conventional backlink. Exported
# extensionless via a Route Handler, so declare text/html. CRITICAL: override the site-wide
# `frame-ancestors 'none'` so third-party sites can actually <iframe> these —
# the whole point is to be embedded anywhere. CORP cross-origin keeps them
# loadable by embedders that run a strict COEP. Self-contained inline-styled
# HTML, no scripts. (More specific path → overrides the /* CSP for these URLs.)
/embed/exam-spec/*
  ! Content-Security-Policy
  Content-Type: text/html; charset=utf-8
  Cross-Origin-Resource-Policy: cross-origin
  Cache-Control: public, max-age=3600
  # Embeddable widgets, not content pages — keep them out of the search index so
  # they don't count as thin content (AdSense low-value audit). Not in sitemap.
  X-Robots-Tag: noindex
