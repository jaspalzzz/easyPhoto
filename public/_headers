# Security headers for static hosting (Netlify / Cloudflare Pages).
# This is a STATIC EXPORT, so headers cannot come from next.config — they are
# applied here at the CDN/host layer. (Vercel: see vercel.json.)
#
# The single highest-leverage control is the CSP `connect-src` allowlist: it
# makes the "your image never leaves your device" promise BROWSER-ENFORCED —
# injected code physically cannot POST image bytes to any origin not listed.
# Once the ML wasm/models are self-hosted, drop the CDN entries and tighten to
# connect-src 'self'.
/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data: blob: https://pagead2.googlesyndication.com; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' blob: https://cdn.jsdelivr.net https://pagead2.googlesyndication.com https://ep2.adtrafficquality.google https://static.cloudflareinsights.com; worker-src 'self' blob: https://cdn.jsdelivr.net; frame-src https://googleads.g.doubleclick.net https://ep2.adtrafficquality.google https://www.google.com; connect-src 'self' blob: https://models.easyphoto.in https://cdn.jsdelivr.net https://storage.googleapis.com https://staticimgly.com https://huggingface.co https://*.huggingface.co https://*.hf.co https://pagead2.googlesyndication.com https://ep1.adtrafficquality.google https://cloudflareinsights.com; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless

# Content-hashed build assets (JS/CSS chunks, bundled wasm/models under media/)
# are immutable — the hash changes when content changes — so cache them forever.
# This is the main lever for the edge cache-hit rate and repeat-visit bandwidth.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Per-page Open Graph cards are emitted as EXTENSIONLESS files (…/opengraph-image).
# With nosniff above, the host must declare the type explicitly or social/SERP
# previews break. Cloudflare Pages reads this _headers file and applies it.
/*opengraph-image
  Content-Type: image/png
  Cache-Control: public, max-age=86400

# The exam-calendar .ics is exported extensionless; declare its type so phones
# hand it to the calendar app instead of showing raw text.
/exam-calendar/ics
  Content-Type: text/calendar; charset=utf-8
  Content-Disposition: attachment; filename="easyphoto-exam-calendar.ics"
